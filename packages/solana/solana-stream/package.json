{
    "name": "@sqd-sdk/solana-stream",
    "version": "0.1.3",
    "description": "SVM block data streamer",
    "license": "GPL-3.0-or-later",
    "repository": "git@github.com:subsquid/squid.git",
    "publishConfig": {
        "access": "public"
    },
    "files": ["lib", "src"],
    "main": "./lib/index.cjs",
    "module": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "scripts": {
        "build": "tsup && pnpm build:types",
        "build:dev": "tsup --config tsup.config.dev.ts && pnpm build:types",
        "build:types": "tsc",
        "pack": "(cd lib && npm pack --pack-destination ..) && rm -f package.tgz && mv sqd-sdk-solana-stream-*.tgz package.tgz",
        "prepublishOnly": "pnpm build && pnpm pack",
        "publish": "npm publish package.tgz",
        "postpublish": "rm -f package.tgz"
    },
    "dependencies": {
        "@sqd-sdk/core": "workspace:../../core/lib",
        "bs58": "^6.0.0"
    },
    "devDependencies": {
        "typescript": "~5.5.4"
    }
}
