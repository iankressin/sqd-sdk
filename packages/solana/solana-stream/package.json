{
    "name": "@sqd-sdk/solana-stream",
    "version": "0.1.3",
    "description": "SVM block data streamer",
    "license": "GPL-3.0-or-later",
    "repository": "git@github.com:subsquid/squid.git",
    "publishConfig": {
        "access": "public"
    },
    "files": ["lib", "src"],
    "main": "./lib/index.cjs",
    "module": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "scripts": {
        "build": "rm -rf lib && tsup && pnpm build:types",
        "build:types": "tsc",
        "pack": "(cd lib && npm pack --pack-destination ..) && rm -f package.tgz && mv sqd-sdk-solana-stream-*.tgz package.tgz",
        "prepublishOnly": "pnpm build && pnpm pack",
        "publish": "npm publish package.tgz",
        "postpublish": "rm -f package.tgz"
    },
    "dependencies": {
        "@sqd-sdk/core": "workspace:../../core/lib",
        "bs58": "^6.0.0"
    },
    "devDependencies": {
        "typescript": "~5.5.4"
    },
    "exports": {
        "./source": {
            "import": {
                "types": "./source.d.ts",
                "default": "./source.js"
            },
            "require": {
                "types": "./source.d.ts",
                "default": "./source.cjs"
            },
            "types": "./source.d.ts",
            "default": "./source.js"
        },
        "./schema": {
            "import": {
                "types": "./schema.d.ts",
                "default": "./schema.js"
            },
            "require": {
                "types": "./schema.d.ts",
                "default": "./schema.cjs"
            },
            "types": "./schema.d.ts",
            "default": "./schema.js"
        },
        "./query": {
            "import": {
                "types": "./query.d.ts",
                "default": "./query.js"
            },
            "require": {
                "types": "./query.d.ts",
                "default": "./query.cjs"
            },
            "types": "./query.d.ts",
            "default": "./query.js"
        },
        "./instruction": {
            "import": {
                "types": "./instruction.d.ts",
                "default": "./instruction.js"
            },
            "require": {
                "types": "./instruction.d.ts",
                "default": "./instruction.cjs"
            },
            "types": "./instruction.d.ts",
            "default": "./instruction.js"
        },
        ".": {
            "import": {
                "types": "./index.d.ts",
                "default": "./index.js"
            },
            "require": {
                "types": "./index.d.ts",
                "default": "./index.cjs"
            },
            "types": "./index.d.ts",
            "default": "./index.js"
        },
        "./objets/types": {
            "import": {
                "types": "./objets/types.d.ts",
                "default": "./objets/types.js"
            },
            "require": {
                "types": "./objets/types.d.cts",
                "default": "./objets/types.cjs"
            },
            "types": "./objets/types.d.ts",
            "default": "./objets/types.js"
        },
        "./objets/relations": {
            "import": {
                "types": "./objets/relations.d.ts",
                "default": "./objets/relations.js"
            },
            "require": {
                "types": "./objets/relations.d.cts",
                "default": "./objets/relations.cjs"
            },
            "types": "./objets/relations.d.ts",
            "default": "./objets/relations.js"
        },
        "./objets/items": {
            "import": {
                "types": "./objets/items.d.ts",
                "default": "./objets/items.js"
            },
            "require": {
                "types": "./objets/items.d.cts",
                "default": "./objets/items.cjs"
            },
            "types": "./objets/items.d.ts",
            "default": "./objets/items.js"
        },
        "./objets": {
            "import": {
                "types": "./objets/index.d.ts",
                "default": "./objets/index.js"
            },
            "require": {
                "types": "./objets/index.d.cts",
                "default": "./objets/index.cjs"
            },
            "types": "./objets/index.d.ts",
            "default": "./objets/index.js"
        }
    }
}
