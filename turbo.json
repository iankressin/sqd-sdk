{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "@sqd-sdk/solana-stream#build": {
        "dependsOn": ["@sqd-sdk/core#build"]
    },
    "solana-example#build": {
        "dependsOn": ["@sqd-sdk/core#build", "@sqd-sdk/solana-stream#build"]
    }
  }
}