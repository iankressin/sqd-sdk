{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "test": {
            "dependsOn": ["^test"]
        },
        "build": {
            "dependsOn": ["^build"]
        },
        "build:dev": {
            "dependsOn": ["^build:dev"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "dev": {
            "persistent": true,
            "cache": false
        },
        "@sqd-sdk/solana-stream#build": {
            "dependsOn": ["@sqd-sdk/core#build"]
        },
        "@sqd-sdk/solana-stream#build:dev": {
            "dependsOn": ["@sqd-sdk/core#build:dev"]
        },
        "@sqd-sdk/solana-stream#test": {
            "dependsOn": ["@sqd-sdk/core#test", "@sqd-sdk/solana-stream#build"]
        },
        "solana-example#build": {
            "dependsOn": ["@sqd-sdk/core#build", "@sqd-sdk/solana-stream#build"]
        }
    }
}